---
import Layout from '../../layouts/layout.astro';
import Comments from '../../components/Comments.astro';
import ShareCard from '../../components/ShareCard.astro';
import { columns } from '../../data/columns';

export function getStaticPaths() {
  return columns.map((column) => ({
    params: { slug: column.slug },
  }));
}

const { slug } = Astro.params;
const column = columns.find(c => c.slug === slug);

if (!column) {
  return Astro.redirect('/column');
}

const categoryEmoji: Record<string, string> = {
  '观点': '💡',
  '诗歌': '🎭',
  '随笔': '📝'
};

// 简单的 Markdown 渲染
function renderMarkdown(content: string): string {
  const lines = content.split('\n');
  let html = '';
  let inList = false;
  let inTable = false;
  let inTableHeader = false;
  let inCodeBlock = false;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];

    // 空行
    if (line.trim() === '') {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      continue;
    }

    // 代码块
    if (line.trim() === '```') {
      if (inCodeBlock) {
        html += '</code></pre>\n';
        inCodeBlock = false;
      } else {
        html += '<pre class="bg-gray-100 dark:bg-gray-800 rounded-lg p-4 mb-6 overflow-x-auto"><code class="text-sm font-mono text-gray-800 dark:text-gray-200">';
        inCodeBlock = true;
      }
      continue;
    }

    if (inCodeBlock) {
      const escaped = line
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
      html += escaped + '\n';
      continue;
    }

    // 分隔线
    if (line.trim() === '---') {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      html += '<hr class="my-8 border-gray-200 dark:border-gray-700" />\n';
      continue;
    }

    // H1 - 跳过（标题已在页面header显示）
    if (line.startsWith('# ') && !line.startsWith('## ')) {
      continue;
    }

    // H2
    if (line.startsWith('## ')) {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      html += `<h2 class="text-xl font-bold text-gray-900 dark:text-white mt-12 mb-5">${line.slice(3)}</h2>\n`;
      continue;
    }

    // H3
    if (line.startsWith('### ')) {
      if (inList) {
        html += '</ul>\n';
        inList = false;
      }
      html += `<h3 class="text-lg font-semibold text-gray-900 dark:text-white mt-10 mb-4">${line.slice(4)}</h3>\n`;
      continue;
    }

    // 表格
    if (line.trim().startsWith('|') && line.includes('|')) {
      // 跳过分隔行
      if (line.match(/^\|[-\s|:]+\|$/)) {
        continue;
      }
      // 解析表格行
      const cells = line.split('|').filter(c => c.trim());
      if (cells.length > 0) {
        if (!inTable) {
          html += '<div class="overflow-x-auto my-6"><table class="min-w-full border border-gray-300 dark:border-gray-600">\n';
          inTable = true;
        }
        const isHeader = !inTableHeader;
        if (isHeader) {
          inTableHeader = true;
          html += '<thead class="bg-gray-100 dark:bg-gray-800">\n';
        }
        html += '<tr>' + cells.map(c => {
          const cellText = c.trim().replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
          return isHeader 
            ? `<th class="border border-gray-300 dark:border-gray-600 px-4 py-2 text-left font-semibold">${cellText}</th>`
            : `<td class="border border-gray-300 dark:border-gray-600 px-4 py-2">${cellText}</td>`;
        }).join('') + '</tr>\n';
        if (isHeader) {
          html += '</thead>\n<tbody>\n';
        }
      }
      continue;
    }

    // 结束表格
    if (inTable && !line.trim().startsWith('|')) {
      html += '</tbody>\n</table>\n</div>\n';
      inTable = false;
      inTableHeader = false;
    }

    // 列表项
    if (line.startsWith('- ')) {
      if (!inList) {
        html += '<ul class="list-disc text-gray-700 dark:text-gray-300 my-4 space-y-2 pl-5 text-[15px] leading-[1.8]">\n';
        inList = true;
      }
      let itemText = line.slice(2);
      // 处理粗体
      itemText = itemText.replace(/\*\*([^*]+)\*\*/g, '<strong class="font-semibold text-gray-900 dark:text-white">$1</strong>');
      // 处理斜体
      itemText = itemText.replace(/\*([^*]+)\*/g, '<em class="italic">$1</em>');
      html += `<li>${itemText}</li>\n`;
      continue;
    }

    // 普通段落
    if (inList) {
      html += '</ul>\n';
      inList = false;
    }
    let paraText = line;
    // 处理粗体
    paraText = paraText.replace(/\*\*([^*]+)\*\*/g, '<strong class="font-semibold text-gray-900 dark:text-white">$1</strong>');
    // 处理斜体
    paraText = paraText.replace(/\*([^*]+)\*/g, '<em class="italic">$1</em>');
    html += `<p class="text-gray-700 dark:text-gray-300 mb-6 leading-[1.8] text-[15px]">${paraText}</p>\n`;
  }

  if (inList) {
    html += '</ul>\n';
  }
  if (inTable) {
    html += '</tbody>\n</table>\n</div>\n';
  }
  if (inCodeBlock) {
    html += '</code></pre>\n';
  }

  return html;
}
---

<Layout title={`${column.title} | 楚萧萧专栏`}>
  <main class="max-w-3xl mx-auto px-6 py-12">
    <article>
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">{categoryEmoji[column.category]}</span>
          <span class="text-sm text-gray-500 dark:text-gray-400">
            {column.category}
          </span>
          <span class="text-sm text-gray-400 dark:text-gray-500">·</span>
          <time class="text-sm text-gray-500 dark:text-gray-400">
            {column.date}
          </time>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          {column.title}
        </h1>
        {column.tags.length > 0 && (
          <div class="flex gap-2">
            {column.tags.map((tag) => (
              <span class="text-sm px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose prose-lg dark:prose-invert max-w-none" set:html={renderMarkdown(column.content)} />
    </article>

    <Comments />

    <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
      <a href="/column" class="text-red-500 hover:text-red-600 transition-colors">
        ← 返回专栏
      </a>
    </footer>
  </main>
</Layout>
