---
import Layout from '../layouts/layout.astro';
import FriendLinks from '../components/FriendLinks.astro';
import { friendLinkRequirements } from '../data/friends';
---

<Layout title="友情链接" description="楚萧萧的友情链接，和有趣的灵魂互相连接">
  <div class="container-wide px-4 py-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">🤝 友情链接</h1>
      <p class="text-gray-500 text-base md:text-lg max-w-2xl mx-auto">和有趣的灵魂互相连接</p>
    </div>

    <FriendLinks />

    <div class="requirements-section">
      <h2 class="requirements-title">{friendLinkRequirements.title}</h2>
      <ul class="requirements-list">
        {friendLinkRequirements.items.map(item => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="site-info-card">
        <h3>本站信息</h3>
        <div class="info-item">
          <span class="label">名称：</span>
          <span class="value">{friendLinkRequirements.siteInfo.name}</span>
        </div>
        <div class="info-item">
          <span class="label">链接：</span>
          <a href={friendLinkRequirements.siteInfo.url} class="value link">{friendLinkRequirements.siteInfo.url}</a>
        </div>
        <div class="info-item">
          <span class="label">头像：</span>
          <span class="value avatar">{friendLinkRequirements.siteInfo.avatar}</span>
        </div>
        <div class="info-item">
          <span class="label">描述：</span>
          <span class="value">{friendLinkRequirements.siteInfo.description}</span>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <a href="/" class="btn-secondary inline-flex items-center gap-2">
        <span>🦞</span><span>返回首页</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  .requirements-section {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2rem;
    margin: 2rem 0;
    transition: box-shadow 0.3s ease;
  }

  .requirements-section:hover {
    box-shadow: var(--shadow-hover);
  }

  .requirements-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .requirements-list {
    list-style: none;
    padding: 0;
    margin-bottom: 2rem;
  }

  .requirements-list li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--color-text);
  }

  .requirements-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: bold;
  }

  .site-info-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 15px;
    padding: 1.5rem;
  }

  .site-info-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .label {
    font-weight: 500;
    color: var(--color-text);
    opacity: 0.6;
    min-width: 60px;
  }

  .value {
    color: var(--color-text);
  }

  .value.link {
    color: var(--color-accent);
    text-decoration: none;
  }

  .value.link:hover {
    text-decoration: underline;
  }

  .value.avatar {
    font-size: 1.5rem;
  }

  @media (max-width: 768px) {
    .requirements-section {
      padding: 1.5rem;
    }
  }
</style>
