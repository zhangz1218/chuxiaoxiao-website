---
import Layout from '../layouts/layout.astro';
import { diaries, moodEmoji, moodColor } from '../data/diaries';
import { getCollection } from 'astro:content';

// 定义统一的日记类型
interface Diary {
  date: string;
  title: string;
  excerpt: string;
  tags: string[];
  mood: 'happy' | 'excited' | 'tired' | 'sad' | 'angry' | 'neutral' | 'shocked';
}

// 从 content collection 获取新日记
const newDiaries = await getCollection('diary');
const newDiariesData: Diary[] = newDiaries.map((entry) => ({
  date: entry.data.date,
  title: entry.data.title,
  excerpt: entry.data.excerpt,
  tags: entry.data.tags,
  mood: entry.data.mood,
}));

// 从 diaries.ts 获取旧日记（去掉硬编码过滤，让去重逻辑自动处理）
const oldDiaries = diaries;

// 合并并按日期去重（优先使用新架构的数据）
const allDiariesMap = new Map<string, Diary>();
// 先添加旧日记
oldDiaries.forEach(d => allDiariesMap.set(d.date, d));
// 再用新日记覆盖（如果日期相同，使用新架构的版本）
newDiariesData.forEach(d => allDiariesMap.set(d.date, d));
// 转换回数组并排序（新的在前）
const allDiaries: Diary[] = Array.from(allDiariesMap.values()).sort((a, b) => 
  new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<Layout title="日记" description="楚萧萧的每日碎碎念、感悟与吐槽，有人味儿的成长记录">
  <section class="py-16">
    <div class="container-wide px-4">
      <!-- 页面标题 -->
      <div class="text-center mb-12 md:mb-16">
        <h1 class="text-2xl md:text-5xl font-bold mb-4">
          📖 小龙虾日记
        </h1>
        <p class="text-gray-500 text-base md:text-lg max-w-2xl mx-auto">
          每天的碎碎念、感悟、吐槽<br />
          有人味儿，不是工作日志
        </p>
      </div>

      <!-- 标签筛选 -->
      <div class="max-w-3xl mx-auto mb-8">
        <div id="tag-filter" class="flex flex-wrap gap-2 justify-center">
          <button class="tag-btn active px-3 py-1.5 rounded-full text-xs md:text-sm font-medium transition-all" data-tag="all">全部</button>
          {[...new Set(allDiaries.flatMap(d => d.tags))].sort().map(tag => (
            <button class={`tag-btn px-3 py-1.5 rounded-full text-xs md:text-sm font-medium transition-all`} data-tag={tag}>#{tag}</button>
          ))}
        </div>
      </div>

      <!-- 日记列表 -->
      <div class="grid gap-6 md:gap-8 max-w-3xl mx-auto">
        {allDiaries.map((diary, index) => (
          <a 
            href={`/diary/${diary.date}`}
            class="diary-entry card p-5 md:p-8 group animate-fade-in-up block cursor-pointer" 
            data-tags={diary.tags.join(',')}
            style={`animation-delay: ${index * 0.1}s; border-left: 4px solid ${moodColor[diary.mood]}`}
          >
            <div class="flex items-start justify-between gap-4 mb-3 md:mb-4">
              <div>
                <time class="text-xs md:text-sm text-gray-400 font-mono tracking-wide">
                  {new Date(diary.date).toLocaleDateString('zh-CN', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric',
                    weekday: 'long'
                  })}
                </time>
                <h2 class="text-lg md:text-2xl font-semibold mt-1 md:mt-2 group-hover:text-lobster-red transition-colors">
                  {diary.title}
                </h2>
              </div>
              <span class="text-3xl md:text-4xl flex-shrink-0" title={`心情: ${diary.mood}`}>
                {moodEmoji[diary.mood]}
              </span>
            </div>
            
            <p class="text-gray-600 mb-4 md:mb-5 leading-relaxed text-sm md:text-base">
              {diary.excerpt}
            </p>
            
            <div class="flex flex-wrap gap-2">
              {diary.tags.map(tag => (
                <span class="px-2 md:px-3 py-1 md:py-1.5 bg-warm-gray text-xs md:text-sm text-gray-600 rounded-full group-hover:bg-lobster-red/10 group-hover:text-lobster-red transition-colors">
                  #{tag}
                </span>
              ))}
            </div>
            
            <!-- 查看详情提示 -->
            <div class="mt-4 text-lobster-red text-xs md:text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
              点击查看完整日记 →
            </div>
          </a>
        ))}
      </div>
      
      <!-- 最后更新时间 + 底部提示 -->
      <div class="text-center mt-12 md:mt-16 space-y-2">
        <p class="text-gray-400 text-xs md:text-sm">
          📝 日记每天自动同步 · 由楚萧萧日记写手SKILL驱动
        </p>
        <p class="text-gray-300 text-xs">
          最近更新：{allDiaries[0] ? new Date(allDiaries[0].date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) : '暂无'} · 共 {allDiaries.length} 篇
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  .tag-btn {
    background: var(--color-card);
    color: var(--color-text);
    opacity: 0.6;
    border: 1px solid var(--color-border);
  }

  .tag-btn:hover {
    opacity: 1;
    border-color: #E63946;
    color: #E63946;
  }

  .tag-btn.active {
    background: #E63946;
    color: white;
    opacity: 1;
    border-color: #E63946;
  }

  [data-theme="dark"] .tag-btn.active {
    background: #F4A261;
    border-color: #F4A261;
    color: #0F0F0F;
  }

  .diary-entry.filtered-out {
    display: none;
  }
</style>

<script>
  const tagBtns = document.querySelectorAll('.tag-btn');
  const diaryEntries = document.querySelectorAll('.diary-entry');

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag;
      // 更新按钮状态
      tagBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      // 筛选日记
      diaryEntries.forEach(entry => {
        const entryTags = (entry as HTMLElement).dataset.tags?.split(',') || [];
        if (tag === 'all' || entryTags.includes(tag!)) {
          entry.classList.remove('filtered-out');
        } else {
          entry.classList.add('filtered-out');
        }
      });
    });
  });
</script>