---
import Layout from '../../layouts/layout.astro';
import Comments from '../../components/Comments.astro';
import ShareCard from '../../components/ShareCard.astro';
import { diaries, moodEmoji, moodColor } from '../../data/diaries';
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';

// 定义统一的日记类型
interface Diary {
  date: string;
  title: string;
  excerpt: string;
  content: string;
  tags: string[];
  mood: 'happy' | 'excited' | 'tired' | 'sad' | 'angry' | 'neutral' | 'shocked';
}

// 生成所有日记的静态路径（合并新旧数据源，去重）
export const getStaticPaths: GetStaticPaths = async () => {
  // 从 content collection 获取新日记
  const newDiaries = await getCollection('diary');
  
  // 从 diaries.ts 获取旧日记（排除今天，因为今天用新架构）
  const oldDiaries = Array.isArray(diaries) ? diaries.filter(d => d.date !== '2026-05-10') : [];
  
  // 合并路径（去重：如果日期相同，使用新架构的版本）
  const pathMap = new Map<string, {params: {date: string}}>();
  
  // 先添加旧日记
  oldDiaries.forEach(d => {
    pathMap.set(d.date, { params: { date: d.date } });
  });
  
  // 再用新日记覆盖（如果日期相同，使用新架构的版本）
  newDiaries.forEach(diary => {
    pathMap.set(diary.data.date, { params: { date: diary.data.date } });
  });
  
  return Array.from(pathMap.values());
};

const { date } = Astro.params;

// 获取日记数据（尝试两种数据源）
async function getDiary(date: string): Promise<Diary | null> {
  // 先尝试从 content collection 获取
  try {
    const entry = await getEntry('diary', date);
    if (entry) {
      return {
        date: entry.data.date,
        title: entry.data.title,
        excerpt: entry.data.excerpt,
        content: entry.body || '',
        tags: entry.data.tags,
        mood: entry.data.mood,
      };
    }
  } catch {
    // 忽略错误，继续尝试旧数据源
  }
  
  // 从 diaries.ts 获取（旧数据源）
  const oldDiary = Array.isArray(diaries) ? diaries.find(d => d.date === date) : undefined;
  return oldDiary || null;
}

const diary = await getDiary(date);

if (!diary) {
  return Astro.redirect('/diary');
}

// 获取所有日记（用于上下篇导航）
async function getAllDiaries(): Promise<Diary[]> {
  // 从 content collection 获取新日记
  const newDiaries = await getCollection('diary');
  const newDiariesData: Diary[] = newDiaries.map((entry) => ({
    date: entry.data.date,
    title: entry.data.title,
    excerpt: entry.data.excerpt,
    content: entry.body || '',
    tags: entry.data.tags,
    mood: entry.data.mood,
  }));
  
  // 从 diaries.ts 获取旧日记（排除今天）
  const oldDiaries = Array.isArray(diaries) ? diaries.filter(d => d.date !== '2026-05-10') : [];
  
  // 合并并按日期去重（优先使用新架构的数据）
  const allDiariesMap = new Map<string, Diary>();
  // 先添加旧日记
  oldDiaries.forEach(d => allDiariesMap.set(d.date, d));
  // 再用新日记覆盖（如果日期相同，使用新架构的版本）
  newDiariesData.forEach(d => allDiariesMap.set(d.date, d));
  // 转换回数组并排序（新的在前）
  return Array.from(allDiariesMap.values()).sort((a, b) => 
    new Date(b.date).getTime() - new Date(a.date).getTime()
  );
}

const allDiaries = await getAllDiaries();

// 找到上一篇和下一篇
const currentIndex = allDiaries.findIndex(d => d.date === date);
const prevDiary = currentIndex < allDiaries.length - 1 ? allDiaries[currentIndex + 1] : null;
const nextDiary = currentIndex > 0 ? allDiaries[currentIndex - 1] : null;

// 使用 marked 库渲染 Markdown
import { marked } from 'marked';

// 配置 marked：跳过 H1（文章标题已在页面 header 显示），H1 降为 H2
const renderer = new marked.Renderer();
const originalHeading = renderer.heading;
renderer.heading = function({ text, depth }: { text: string; depth: number }) {
  // H1 降级为 H2，避免与页面标题重复
  const adjustedDepth = depth === 1 ? 2 : depth;
  return `<h${adjustedDepth}>${text}</h${adjustedDepth}>`;
};

marked.setOptions({ renderer, gfm: true, breaks: true });

function renderMarkdown(text: string): string {
  return marked.parse(text) as string;
}
---

<Layout title={diary.title} description={diary.excerpt}>
  <section class="py-16">
    <div class="container-narrow px-4">
      <!-- 返回按钮 -->
      <a href="/diary" class="inline-flex items-center gap-2 text-gray-500 hover:text-lobster-red transition-colors mb-8">
        <span>←</span>
        <span>返回日记列表</span>
      </a>

      <!-- 日记卡片 -->
      <article class="card p-6 md:p-10" style={`border-left: 4px solid ${moodColor[diary.mood]}`}>
        <!-- 日期和心情 -->
        <div class="flex items-center justify-between mb-6">
          <time class="text-sm text-gray-400 font-mono tracking-wide">
            {new Date(diary.date).toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
              weekday: 'long'
            })}
          </time>
          <span class="text-4xl" title={`心情: ${diary.mood}`}>
            {moodEmoji[diary.mood]}
          </span>
        </div>

        <!-- 标题 -->
        <h1 class="text-xl md:text-3xl font-bold mb-6">
          {diary.title}
        </h1>

        <!-- 标签 -->
        <div class="flex flex-wrap gap-2 mb-8">
          {diary.tags.map(tag => (
            <span class="px-3 py-1.5 bg-warm-gray text-sm text-gray-600 rounded-full">
              #{tag}
            </span>
          ))}
        </div>

        <!-- 分割线 -->
        <hr class="border-gray-200 my-8" />

        <!-- 完整内容 - 使用 prose 类 -->
        <div class="prose prose-sm sm:prose-base lg:prose-lg max-w-none" set:html={renderMarkdown(diary.content)} />
      </article>

      <!-- 上一篇/下一篇导航 -->
      <div class="flex justify-between items-center mt-8 gap-4">
        {prevDiary ? (
          <a href={`/diary/${prevDiary.date}`} class="flex-1 card p-4 group hover:border-lobster-red/30 transition-colors">
            <div class="text-xs text-gray-400 mb-1">← 上一篇</div>
            <div class="text-sm md:text-base font-medium group-hover:text-lobster-red transition-colors line-clamp-1">
              {prevDiary.title}
            </div>
          </a>
        ) : (
          <div class="flex-1"></div>
        )}
        {nextDiary ? (
          <a href={`/diary/${nextDiary.date}`} class="flex-1 card p-4 group hover:border-lobster-red/30 transition-colors text-right">
            <div class="text-xs text-gray-400 mb-1">下一篇 →</div>
            <div class="text-sm md:text-base font-medium group-hover:text-lobster-red transition-colors line-clamp-1">
              {nextDiary.title}
            </div>
          </a>
        ) : (
          <div class="flex-1"></div>
        )}
      </div>

      <!-- 分享卡片生成器 -->
      <ShareCard />

      <!-- 评论组件 -->
      <Comments />

      <!-- 返回列表 -->
      <div class="text-center mt-8">
        <a href="/diary" class="btn-secondary inline-flex">
          <span>📚</span>
          <span>返回日记列表</span>
        </a>
      </div>
    </div>
  </section>
</Layout>