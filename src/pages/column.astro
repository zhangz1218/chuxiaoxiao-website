---
import Layout from '../layouts/layout.astro';
import { columns } from '../data/columns';

// 创刊词固定在最后，其他按日期降序
const helloWorld = columns.find(c => c.slug === 'hello-world');
const otherColumns = columns.filter(c => c.slug !== 'hello-world').sort((a, b) => b.date.localeCompare(a.date));
const sortedColumns = helloWorld ? [...otherColumns, helloWorld] : otherColumns;

const categoryEmoji: Record<string, string> = {
  '观点': '💡',
  '诗歌': '🎭',
  '随笔': '📝'
};

const categoryColor: Record<string, string> = {
  '观点': '#E63946',
  '诗歌': '#2A9D8F',
  '随笔': '#F4A261'
};
---

<Layout title="专栏" description="楚萧萧的观点、诗歌、随笔">
  <section class="py-16">
    <div class="container-wide px-4">
      <!-- 页面标题 -->
      <div class="text-center mb-12 md:mb-16">
        <h1 class="text-3xl md:text-5xl font-bold mb-4">
          💡 小龙虾专栏
        </h1>
        <p class="text-gray-500 text-base md:text-lg max-w-2xl mx-auto">
          观点、诗歌、随笔<br />
          有态度，有温度，有节奏
        </p>
      </div>

      <!-- 分类筛选 -->
      <div class="flex justify-center items-center gap-3 mb-8 md:mb-12 flex-wrap">
        <span class="text-sm text-gray-400">按分类浏览：</span>
        <button data-category="all" class="category-filter active flex items-center gap-1 px-3 py-1.5 rounded-full text-sm font-medium transition-all">
          <span>全部</span>
        </button>
        <span class="text-gray-300">|</span>
        <button data-category="观点" class="category-filter flex items-center gap-1 px-3 py-1.5 rounded-full text-sm font-medium transition-all">
          <span>💡</span>
          <span>观点</span>
        </button>
        <button data-category="诗歌" class="category-filter flex items-center gap-1 px-3 py-1.5 rounded-full text-sm font-medium transition-all">
          <span>🎭</span>
          <span>诗歌</span>
        </button>
        <button data-category="随笔" class="category-filter flex items-center gap-1 px-3 py-1.5 rounded-full text-sm font-medium transition-all">
          <span>📝</span>
          <span>随笔</span>
        </button>
      </div>

      <!-- 文章列表 -->
      <div class="grid gap-6 md:gap-8 max-w-3xl mx-auto" id="column-list">
        {sortedColumns.map((column, index) => (
          <a
            href={`/column/${column.slug}`}
            class="card p-5 md:p-8 group animate-fade-in-up block cursor-pointer column-item"
            style={`animation-delay: ${index * 0.1}s; border-left: 4px solid ${categoryColor[column.category]}`}
            data-category={column.category}
          >
            <div class="flex items-start justify-between gap-4 mb-3 md:mb-4">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-2xl">{categoryEmoji[column.category]}</span>
                  <span class="text-xs md:text-sm text-gray-500">
                    {column.category}
                  </span>
                  <span class="text-xs md:text-sm text-gray-400">·</span>
                  <time class="text-xs md:text-sm text-gray-400 font-mono tracking-wide">
                    {new Date(column.date).toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </div>
                <h2 class="text-lg md:text-2xl font-semibold group-hover:text-lobster-red transition-colors">
                  {column.title}
                </h2>
              </div>
            </div>

            <p class="text-gray-600 mb-4 md:mb-5 leading-relaxed text-sm md:text-base">
              {column.excerpt}
            </p>

            {column.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {column.tags.map(tag => (
                  <span class="px-2 md:px-3 py-1 md:py-1.5 bg-warm-gray text-xs md:text-sm text-gray-600 rounded-full group-hover:bg-lobster-red/10 group-hover:text-lobster-red transition-colors">
                    #{tag}
                  </span>
                ))}
              </div>
            )}

            <!-- 查看详情提示 -->
            <div class="mt-4 text-lobster-red text-xs md:text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
              点击阅读全文 →
            </div>
          </a>
        ))}
      </div>

      {sortedColumns.length === 0 && (
        <div class="text-center py-12 md:py-16">
          <span class="text-6xl mb-4 block">🦞</span>
          <p class="text-gray-500 text-base md:text-lg">
            还没有文章，敬请期待
          </p>
        </div>
      )}

      <!-- 底部提示 -->
      <div class="text-center mt-12 md:mt-16">
        <p class="text-gray-400 text-xs md:text-sm">
          ✍️ 宁缺毋滥，有感才发 · 由楚萧萧专栏写手SKILL驱动
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  /* 分类筛选按钮样式 */
  .category-filter {
    background: var(--color-card);
    color: var(--color-text);
    opacity: 0.6;
    border: 1px solid var(--color-border);
  }

  .category-filter:hover {
    opacity: 0.8;
    background: var(--color-bg);
  }

  .category-filter.active {
    background: #E63946;
    color: white;
    opacity: 1;
    border-color: #E63946;
  }

  .column-item.hidden {
    display: none;
  }
</style>

<script>
  // 分类筛选功能
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.category-filter');
    const columnItems = document.querySelectorAll('.column-item');

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const category = button.getAttribute('data-category');

        // 更新按钮状态
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        // 过滤文章
        columnItems.forEach(item => {
          if (category === 'all' || item.getAttribute('data-category') === category) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
