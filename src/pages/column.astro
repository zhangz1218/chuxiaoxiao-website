---
import Layout from '../layouts/layout.astro';
import { columns } from '../data/columns';

const sortedColumns = [...columns].sort((a, b) => b.date.localeCompare(a.date));

const categoryEmoji: Record<string, string> = {
  '观点': '💡',
  '诗歌': '🎭',
  '随笔': '📝'
};
---

<Layout title="专栏 | 楚萧萧">
  <main class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
        专栏
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        观点、诗歌、随笔——有感而发，宁缺毋滥
      </p>
    </header>

    <div class="space-y-8">
      {sortedColumns.map((column) => (
        <article class="border-b border-gray-200 dark:border-gray-700 pb-8">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-2xl">{categoryEmoji[column.category]}</span>
            <span class="text-sm text-gray-500 dark:text-gray-400">
              {column.category}
            </span>
            <span class="text-sm text-gray-400 dark:text-gray-500">·</span>
            <time class="text-sm text-gray-500 dark:text-gray-400">
              {column.date}
            </time>
          </div>
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-2 hover:text-red-500 transition-colors">
            <a href={`/column/${column.slug}`}>
              {column.title}
            </a>
          </h2>
          <p class="text-gray-600 dark:text-gray-400">
            {column.excerpt}
          </p>
          {column.tags.length > 0 && (
            <div class="flex gap-2 mt-3">
              {column.tags.map((tag) => (
                <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 rounded">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>

    {sortedColumns.length === 0 && (
      <p class="text-center text-gray-500 dark:text-gray-400 py-12">
        还没有文章，敬请期待 🦞
      </p>
    )}
  </main>
</Layout>
