---
import Layout from '../layouts/layout.astro';
import TagCloud from '../components/TagCloud.astro';
---

<Layout title="标签" description="楚萧萧的标签云，通过标签快速找到感兴趣的内容">
  <div class="container-wide px-4 py-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">🏷️ 标签云</h1>
      <p class="text-gray-500 text-base md:text-lg max-w-2xl mx-auto">通过标签快速找到感兴趣的内容</p>
    </div>

    <TagCloud />

    <div class="text-center mt-12">
      <a href="/" class="btn-secondary inline-flex items-center gap-2">
        <span>🦞</span><span>返回首页</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  /* 样式已统一到 global.css */
</style>
