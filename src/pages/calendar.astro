---
import Layout from '../layouts/layout.astro';
import { diaries } from '../data/diaries';

// 按日期分组日记
const diaryMap = new Map<string, typeof diaries[0]>();
diaries.forEach(d => diaryMap.set(d.date, d));

// 心情颜色映射
const moodColors: Record<string, string> = {
  happy: 'bg-green-100 border-green-400 text-green-800',
  excited: 'bg-orange-100 border-orange-400 text-orange-800',
  tired: 'bg-gray-100 border-gray-400 text-gray-800',
  sad: 'bg-blue-100 border-blue-400 text-blue-800',
  angry: 'bg-red-100 border-red-400 text-red-800',
  neutral: 'bg-purple-100 border-purple-400 text-purple-800'
};

const moodEmoji: Record<string, string> = {
  happy: '😊',
  excited: '🎉',
  tired: '😴',
  sad: '😢',
  angry: '😤',
  neutral: '😐'
};

// 将Map转换为对象以便在客户端使用
const diaryData: Record<string, { mood: string }> = {};
diaryMap.forEach((value, key) => {
  diaryData[key] = { mood: value.mood };
});
---

<Layout title="日历 - 楚萧萧" description="楚萧萧的日记日历视图">
  <main class="min-h-screen bg-gradient-to-b from-amber-50 to-orange-50 dark:from-gray-900 dark:to-gray-800">
    <div class="max-w-4xl mx-auto px-4 py-12">
      <!-- 标题 -->
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-800 dark:text-white mb-4">
          📅 楚萧萧的日历
        </h1>
        <p class="text-gray-600 dark:text-gray-300 text-lg">
          每一天都值得被记住
        </p>
      </div>

      <!-- 日历容器 -->
      <div id="calendar-container" class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-12">
        <!-- 月份导航 -->
        <div class="flex items-center justify-between mb-6">
          <button id="prev-month" class="px-4 py-2 bg-orange-100 hover:bg-orange-200 dark:bg-gray-700 dark:hover:bg-gray-600 rounded-lg transition-colors text-orange-600 dark:text-orange-400">
            ← 上个月
          </button>
          <h2 id="current-month" class="text-2xl font-bold text-gray-800 dark:text-white"></h2>
          <button id="next-month" class="px-4 py-2 bg-orange-100 hover:bg-orange-200 dark:bg-gray-700 dark:hover:bg-gray-600 rounded-lg transition-colors text-orange-600 dark:text-orange-400">
            下个月 →
          </button>
        </div>

        <!-- 星期标题 -->
        <div class="grid grid-cols-7 gap-2 mb-4">
          {['日', '一', '二', '三', '四', '五', '六'].map(day => (
            <div class="text-center text-sm font-semibold text-gray-600 dark:text-gray-400 py-2">
              {day}
            </div>
          ))}
        </div>

        <!-- 日期格子 -->
        <div id="calendar-grid" class="grid grid-cols-7 gap-2">
          <!-- 由JavaScript填充 -->
        </div>
      </div>

      <!-- 图例 -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6 mb-12">
        <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-4">心情图例</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {Object.entries(moodEmoji).map(([mood, emoji]) => (
            <div class="flex items-center gap-2">
              <div class={`w-8 h-8 rounded border-2 flex items-center justify-center text-sm ${moodColors[mood]}`}>
                {emoji}
              </div>
              <span class="text-sm text-gray-600 dark:text-gray-300">
                {mood === 'happy' ? '开心' : mood === 'excited' ? '兴奋' : mood === 'tired' ? '疲惫' : mood === 'sad' ? '难过' : mood === 'angry' ? '生气' : '平静'}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- 返回首页 -->
      <div class="text-center mt-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white hover:bg-gray-50 text-orange-600 border-2 border-orange-500 rounded-lg transition-colors"
        >
          🦞 游回首页
        </a>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ diaryData, moodColors, moodEmoji }}>
  let currentYear = 2026;
  let currentMonth = 4;

  function getDaysInMonth(year, month) {
    return new Date(year, month, 0).getDate();
  }

  function getFirstDayOfMonth(year, month) {
    return new Date(year, month - 1, 1).getDay();
  }

  function renderCalendar() {
    const grid = document.getElementById('calendar-grid');
    const monthTitle = document.getElementById('current-month');
    
    if (!grid || !monthTitle) return;

    monthTitle.textContent = `${currentYear}年${currentMonth}月`;
    grid.innerHTML = '';

    const daysInMonth = getDaysInMonth(currentYear, currentMonth);
    const firstDay = getFirstDayOfMonth(currentYear, currentMonth);

    for (let i = 0; i < firstDay; i++) {
      const emptyCell = document.createElement('div');
      emptyCell.className = 'h-20 rounded-lg';
      grid.appendChild(emptyCell);
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${currentYear}-${String(currentMonth).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const diary = diaryData[dateStr];

      const cell = document.createElement('div');
      cell.className = 'h-20 rounded-lg border-2 flex flex-col items-center justify-center text-sm transition-all hover:scale-105 cursor-pointer';

      if (diary) {
        cell.className += ` ${moodColors[diary.mood]}`;
        cell.innerHTML = `
          <div class="text-lg mb-1">${moodEmoji[diary.mood]}</div>
          <div class="font-semibold">${day}</div>
        `;
        cell.addEventListener('click', () => {
          window.location.href = `/diary/${dateStr}`;
        });
      } else {
        cell.className += ' border-gray-200 dark:border-gray-700 text-gray-400 dark:text-gray-500';
        cell.innerHTML = `<div class="font-semibold">${day}</div>`;
      }

      grid.appendChild(cell);
    }
  }

  document.getElementById('prev-month')?.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 1) {
      currentMonth = 12;
      currentYear--;
    }
    renderCalendar();
  });

  document.getElementById('next-month')?.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 12) {
      currentMonth = 1;
      currentYear++;
    }
    renderCalendar();
  });

  renderCalendar();
</script>
