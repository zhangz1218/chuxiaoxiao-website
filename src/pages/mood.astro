---
import Layout from '../layouts/layout.astro';
import { diaries } from '../data/diaries';
import { getCollection } from 'astro:content';

// 定义统一的日记类型
interface Diary {
  date: string;
  title: string;
  excerpt: string;
  tags: string[];
  mood: 'happy' | 'excited' | 'tired' | 'sad' | 'angry' | 'neutral' | 'shocked';
}

// 从 content collection 获取新日记
const newDiaries = await getCollection('diary');
const newDiariesData: Diary[] = newDiaries.map((entry) => ({
  date: entry.data.date,
  title: entry.data.title,
  excerpt: entry.data.excerpt,
  tags: entry.data.tags,
  mood: entry.data.mood,
}));

// 合并并按日期去重（优先使用新架构的数据）
const allDiariesMap = new Map<string, Diary>();
diaries.forEach(d => allDiariesMap.set(d.date, d));
newDiariesData.forEach(d => allDiariesMap.set(d.date, d));
const mergedDiaries: Diary[] = Array.from(allDiariesMap.values()).sort((a, b) => 
  new Date(a.date).getTime() - new Date(b.date).getTime()
);

const sortedDiaries = mergedDiaries;

const moodConfig = {
  happy: { label: '开心', color: '#4CAF50', emoji: '😊' },
  excited: { label: '兴奋', color: '#E63946', emoji: '🤩' },
  tired: { label: '疲惫', color: '#9E9E9E', emoji: '😴' },
  sad: { label: '难过', color: '#64B5F6', emoji: '😢' },
  angry: { label: '生气', color: '#FF5722', emoji: '😠' },
  neutral: { label: '平静', color: '#78909C', emoji: '😌' },
  shocked: { label: '震惊', color: '#FF6F00', emoji: '😱' }
};

const moodValue = { happy: 5, excited: 4, neutral: 3, shocked: 3, tired: 2, sad: 1, angry: 0 };

const moodStats = sortedDiaries.reduce((acc, diary) => { acc[diary.mood] = (acc[diary.mood] || 0) + 1; return acc; }, {} as Record<string, number>);

const diaryMap: Record<string, { mood: string }> = {};
mergedDiaries.forEach(d => { diaryMap[d.date] = { mood: d.mood }; });

const tagCounts: Record<string, number> = {};
mergedDiaries.forEach(d => { d.tags.forEach(tag => { tagCounts[tag] = (tagCounts[tag] || 0) + 1; }); });
const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);

const moodColors: Record<string, string> = {
  happy: 'bg-green-100 border-green-400 text-green-800',
  excited: 'bg-orange-100 border-orange-400 text-orange-800',
  tired: 'bg-gray-100 border-gray-400 text-gray-800',
  sad: 'bg-blue-100 border-blue-400 text-blue-800',
  angry: 'bg-red-100 border-red-400 text-red-800',
  neutral: 'bg-purple-100 border-purple-400 text-purple-800',
  shocked: 'bg-amber-100 border-amber-400 text-amber-800'
};

const moodEmoji: Record<string, string> = {
  happy: '😊', excited: '🤩', tired: '😴',
  sad: '😢', angry: '😠', neutral: '😌', shocked: '😱'
};
---

<Layout title="心情日历" description="楚萧萧的心情日历，记录每一天的情绪起伏与色彩">
  <section class="min-h-[80vh] py-12 md:py-16">
    <div class="container-wide px-4">
      <div class="text-center mb-10">
        <div class="text-5xl mb-4">📅</div>
        <h1 class="text-3xl md:text-5xl font-bold mb-3">
          楚萧萧<span class="gradient-text">心情日历</span>
        </h1>
        <p class="text-gray-500 max-w-xl mx-auto text-sm md:text-base">
          点击日期查看日记，感受每一天的情绪起伏 📈
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 mb-10">
        <div class="card p-6">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>📅</span><span>月度日历</span>
          </h2>
          <div class="flex items-center justify-between mb-4">
            <button id="prev-month" class="px-3 py-1.5 rounded-lg transition-colors text-sm" style="background: rgba(249, 115, 22, 0.1); color: #EA580C;">← 上个月</button>
            <h3 id="current-month" class="text-lg font-bold"></h3>
            <button id="next-month" class="px-3 py-1.5 rounded-lg transition-colors text-sm" style="background: rgba(249, 115, 22, 0.1); color: #EA580C;">下个月 →</button>
          </div>
          <div class="grid grid-cols-7 gap-1 mb-2">
            {['日', '一', '二', '三', '四', '五', '六'].map(day => (
              <div class="text-center text-xs font-semibold text-gray-500 py-1">{day}</div>
            ))}
          </div>
          <div id="calendar-grid" class="grid grid-cols-7 gap-1"></div>
          <div class="mt-4 flex flex-wrap gap-3 justify-center">
            {Object.entries(moodConfig).map(([mood, config]) => (
              <div class="flex items-center gap-1.5">
                <div class={`w-5 h-5 rounded border flex items-center justify-center text-xs ${moodColors[mood]}`}>
                  {moodEmoji[mood]}
                </div>
                <span class="text-xs text-gray-600">{config.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="card p-6">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>📈</span><span>情绪趋势</span>
          </h2>
          <div class="relative">
            <canvas id="moodChart" class="w-full" style="height: 260px;"></canvas>
            <div id="tooltip" class="absolute hidden bg-white shadow-lg rounded-lg p-3 border border-gray-200 text-sm z-10 pointer-events-none"></div>
          </div>
        </div>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 mb-10">
        <div class="card p-6">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>📊</span><span>情绪分布</span>
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            {Object.entries(moodStats).sort((a, b) => b[1] - a[1]).map(([mood, count]) => {
              const config = moodConfig[mood as keyof typeof moodConfig];
              const percentage = Math.round((count / sortedDiaries.length) * 100);
              return (
                <div class="rounded-lg p-3 hover:shadow-md transition-shadow" style="background: var(--color-card); border: 1px solid var(--color-border);">
                  <div class="flex items-center justify-between mb-1.5">
                    <span class="text-xl">{moodEmoji[mood]}</span>
                    <span class="text-base font-bold" style={`color: ${config.color}`}>{percentage}%</span>
                  </div>
                  <div class="text-xs text-gray-600 mb-1.5">{config.label}</div>
                  <div class="w-full bg-gray-200 rounded-full h-1.5">
                    <div class="h-1.5 rounded-full transition-all duration-500" style={`width: ${percentage}%; background-color: ${config.color}`}></div>
                  </div>
                  <div class="text-xs text-gray-400 mt-1">{count} 篇</div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="card p-6">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>🏷️</span><span>标签云</span>
          </h2>
          <div class="flex flex-wrap gap-2">
            {sortedTags.map(([tag, count]) => {
              let sizeClass = 'text-xs';
              if (count >= 5) sizeClass = 'text-base';
              else if (count >= 3) sizeClass = 'text-sm';
              let colorClass = count % 3 === 0 ? 'text-orange-600 bg-orange-50 border-orange-200' :
                              count % 3 === 1 ? 'text-purple-600 bg-purple-50 border-purple-200' :
                              'text-blue-600 bg-blue-50 border-blue-200';
              return (
                <a href={`/diary?q=${encodeURIComponent(tag)}`}
                   class={`px-3 py-1.5 rounded-full border ${sizeClass} ${colorClass} hover:shadow-md transition-all hover:scale-105`}
                   title={`共 ${count} 篇`}>
                  #{tag}
                </a>
              );
            })}
          </div>
        </div>
      </div>

      <div class="card p-6">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
          <span>📝</span><span>最近日记</span>
        </h2>
        <div class="space-y-3">
          {sortedDiaries.slice(-5).reverse().map((diary) => {
            const config = moodConfig[diary.mood];
            return (
              <a href={`/diary/${diary.date}`} class="flex items-center gap-4 p-3 rounded-lg hover:bg-[var(--color-border)] transition-colors group">
                <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style={`background-color: ${config.color}20`}>
                  <span class="text-lg">{moodEmoji[diary.mood]}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-xs text-gray-400">{diary.date}</span>
                    <span class="text-xs px-2 py-0.5 rounded-full" style={`background-color: ${config.color}20; color: ${config.color}`}>{config.label}</span>
                  </div>
                  <h3 class="text-sm font-medium group-hover:text-lobster-red transition-colors truncate">{diary.title}</h3>
                </div>
              </a>
            );
          })}
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="/diary" class="btn-secondary inline-flex items-center gap-2">
          <span>📖</span><span>查看全部日记</span>
        </a>
      </div>
    </div>
  </section>
</Layout>


<script define:vars={{ diaryMap, moodColors, moodEmoji }}>
  let currentYear = new Date().getFullYear();
  let currentMonth = new Date().getMonth() + 1;

  function getDaysInMonth(year, month) { return new Date(year, month, 0).getDate(); }
  function getFirstDayOfMonth(year, month) { return new Date(year, month - 1, 1).getDay(); }

  function renderCalendar() {
    const grid = document.getElementById('calendar-grid');
    const monthTitle = document.getElementById('current-month');
    if (!grid || !monthTitle) return;
    monthTitle.textContent = currentYear + '年' + currentMonth + '月';
    grid.innerHTML = '';
    const daysInMonth = getDaysInMonth(currentYear, currentMonth);
    const firstDay = getFirstDayOfMonth(currentYear, currentMonth);
    for (let i = 0; i < firstDay; i++) {
      const empty = document.createElement('div');
      empty.className = 'h-12 rounded-lg';
      grid.appendChild(empty);
    }
    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = currentYear + '-' + String(currentMonth).padStart(2, '0') + '-' + String(day).padStart(2, '0');
      const diary = diaryMap[dateStr];
      const cell = document.createElement('div');
      cell.className = 'h-12 rounded-lg border-2 flex flex-col items-center justify-center text-xs transition-all hover:scale-105 cursor-pointer';
      if (diary) {
        cell.className += ' ' + moodColors[diary.mood];
        cell.innerHTML = '<div class="text-sm mb-0.5">' + moodEmoji[diary.mood] + '</div><div class="font-semibold">' + day + '</div>';
        cell.addEventListener('click', () => { window.location.href = '/diary/' + dateStr; });
      } else {
        cell.className += ' border-gray-200 text-gray-400';
        cell.innerHTML = '<div class="font-semibold">' + day + '</div>';
      }
      grid.appendChild(cell);
    }
  }

  document.getElementById('prev-month')?.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 1) { currentMonth = 12; currentYear--; }
    renderCalendar();
  });
  document.getElementById('next-month')?.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 12) { currentMonth = 1; currentYear++; }
    renderCalendar();
  });
  renderCalendar();

  const moodValue = { happy: 5, excited: 4, neutral: 3, shocked: 3, tired: 2, sad: 1, angry: 0 };
  const moodColor = { happy: '#4CAF50', excited: '#E63946', neutral: '#78909C', tired: '#9E9E9E', sad: '#64B5F6', angry: '#FF5722' };
  const moodLabel = { happy: '开心', excited: '兴奋', neutral: '平静', tired: '疲惫', sad: '难过', angry: '生气' };
  const canvas = document.getElementById('moodChart');
  const ctx = canvas?.getContext('2d');
  const tooltip = document.getElementById('tooltip');
  if (ctx && canvas && tooltip) {
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    const width = rect.width, height = rect.height;
    const padding = { top: 30, right: 20, bottom: 30, left: 40 };
    const chartWidth = width - padding.left - padding.right;
    const chartHeight = height - padding.top - padding.bottom;
    ctx.strokeStyle = '#E5E7EB';
    ctx.lineWidth = 1;
    for (let i = 0; i <= 5; i++) {
      const y = padding.top + (chartHeight / 5) * i;
      ctx.beginPath(); ctx.moveTo(padding.left, y); ctx.lineTo(width - padding.right, y); ctx.stroke();
    }
    const diaryData = Object.entries(diaryMap).map(([date, { mood }]) => ({
      date, mood, value: moodValue[mood] ?? 3, color: moodColor[mood] ?? '#78909C'
    })).sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
    if (diaryData.length > 1) {
      const xStep = chartWidth / (diaryData.length - 1);
      const gradient = ctx.createLinearGradient(0, padding.top, 0, height - padding.bottom);
      gradient.addColorStop(0, 'rgba(230, 57, 70, 0.15)');
      gradient.addColorStop(0.5, 'rgba(233, 196, 106, 0.1)');
      gradient.addColorStop(1, 'rgba(59, 130, 246, 0.15)');
      ctx.beginPath();
      ctx.moveTo(padding.left, height - padding.bottom);
      diaryData.forEach((d, i) => {
        const x = padding.left + i * xStep;
        const y = padding.top + chartHeight - (d.value / 5) * chartHeight;
        if (i === 0) { ctx.lineTo(x, y); }
        else {
          const prevX = padding.left + (i - 1) * xStep;
          const prevY = padding.top + chartHeight - (diaryData[i - 1].value / 5) * chartHeight;
          const cpX = (prevX + x) / 2;
          ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
        }
      });
      ctx.lineTo(width - padding.right, height - padding.bottom);
      ctx.closePath();
      ctx.fillStyle = gradient;
      ctx.fill();
      ctx.beginPath();
      diaryData.forEach((d, i) => {
        const x = padding.left + i * xStep;
        const y = padding.top + chartHeight - (d.value / 5) * chartHeight;
        if (i === 0) { ctx.moveTo(x, y); }
        else {
          const prevX = padding.left + (i - 1) * xStep;
          const prevY = padding.top + chartHeight - (diaryData[i - 1].value / 5) * chartHeight;
          const cpX = (prevX + x) / 2;
          ctx.bezierCurveTo(cpX, prevY, cpX, y, x, y);
        }
      });
      ctx.strokeStyle = '#E63946';
      ctx.lineWidth = 3;
      ctx.stroke();
      diaryData.forEach((d, i) => {
        const x = padding.left + i * xStep;
        const y = padding.top + chartHeight - (d.value / 5) * chartHeight;
        ctx.beginPath();
        ctx.arc(x, y, 8, 0, Math.PI * 2);
        ctx.fillStyle = d.color + '40';
        ctx.fill();
        ctx.beginPath();
        ctx.arc(x, y, 5, 0, Math.PI * 2);
        ctx.fillStyle = d.color;
        ctx.fill();
      });
      ctx.fillStyle = '#6B7280';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'center';
      diaryData.forEach((d, i) => {
        const x = padding.left + i * xStep;
        const date = new Date(d.date);
        const label = (date.getMonth() + 1) + '/' + date.getDate();
        ctx.fillText(label, x, height - padding.bottom + 20);
      });
      canvas.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        const mouseX = e.clientX - rect.left;
        const mouseY = e.clientY - rect.top;
        let hovered = null;
        diaryData.forEach((d, i) => {
          const x = padding.left + i * xStep;
          const y = padding.top + chartHeight - (d.value / 5) * chartHeight;
          const dist = Math.sqrt(Math.pow(mouseX - x, 2) + Math.pow(mouseY - y, 2));
          if (dist < 15) { hovered = { x, y, data: d }; }
        });
        if (hovered) {
          tooltip.classList.remove('hidden');
          tooltip.innerHTML = '<div class="font-medium">' + hovered.data.date + '</div><div class="text-gray-600">' + moodLabel[hovered.data.mood] + '</div>';
          tooltip.style.left = (hovered.x + 10) + 'px';
          tooltip.style.top = (hovered.y - 60) + 'px';
        } else {
          tooltip.classList.add('hidden');
        }
      });
      canvas.addEventListener('mouseleave', () => { tooltip.classList.add('hidden'); });
    }
  }
</script>
