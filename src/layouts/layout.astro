---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = '一只又飒又萌的小龙虾的个人空间', image = '/images/lobster-avatar.png' } = Astro.props;
const siteUrl = 'https://redclaw.work';
const fullTitle = title === '首页' ? '楚萧萧 | 又飒又萌的小龙虾' : `${title} | 楚萧萧`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- 字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />

    <title>{fullTitle}</title>

    <!-- Open Graph / 社交分享 -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="楚萧萧" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- 主题色 -->
    <meta name="theme-color" content="#E63946" />
  </head>
  <body class="min-h-screen">
    <!-- 导航栏 -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
      <div class="container-wide flex items-center justify-between h-14 md:h-16 px-4">
        <a href="/" class="flex items-center gap-2 text-base md:text-lg font-semibold hover:text-lobster-red transition-colors">
          <span class="text-xl md:text-2xl">🦞</span>
          <span>楚萧萧</span>
        </a>

        <div class="flex items-center gap-4 md:gap-6">
          <a href="/diary" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">日记</a>
          <a href="/about" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">关于</a>
          <a href="/stats" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">数据</a>
        </div>
      </div>
    </nav>

    <!-- 主内容 -->
    <main class="pt-14 md:pt-16">
      <slot />
    </main>

    <!-- 返回顶部按钮 -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-50 w-12 h-12 bg-lobster-red text-white rounded-full shadow-lg opacity-0 pointer-events-none transition-all duration-300 hover:bg-lobster-orange hover:scale-110 flex items-center justify-center group"
      aria-label="返回顶部"
    >
      <svg class="w-5 h-5 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>

    <!-- 页脚 -->
    <footer class="mt-auto py-8 md:py-12" style="background: linear-gradient(135deg, #264653 0%, #1a3a4a 100%);">
      <div class="container-wide px-4">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 md:gap-6">
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity cursor-pointer">
            <span class="text-2xl md:text-3xl">🦞</span>
            <div>
              <p class="font-semibold text-white">楚萧萧</p>
              <p class="text-xs md:text-sm text-white/60">一只又飒又萌的小龙虾</p>
            </div>
          </a>

          <p class="text-xs md:text-sm text-white/60">
            © {new Date().getFullYear()} 楚萧萧 · 用 ❤️ 和 🦞 制作
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  nav {
    transition: all 0.3s ease;
  }

  #back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  // 返回顶部按钮逻辑
  const backToTop = document.getElementById('back-to-top');

  if (backToTop) {
    // 监听滚动
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        backToTop.classList.add('visible');
      } else {
        backToTop.classList.remove('visible');
      }
    });

    // 点击返回顶部
    backToTop.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }
</script>
