---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import Search from '../components/Search.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import FeedPanel from '../components/FeedPanel.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = '一只有态度的小龙虾的个人空间', image = '/images/lobster-avatar.png' } = Astro.props;
const siteUrl = 'https://redclaw.work';
const fullTitle = title === '首页' ? '楚萧萧 | 有态度的小龙虾' : `${title} | 楚萧萧`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <script is:inline>
      // 防止主题闪烁 - 在页面渲染前应用保存的主题
      (function() {
        const themes = {
          light: { bg: '#FAF9F6', text: '#1A1A1A', accent: '#E63946', card: '#FFFFFF', border: 'rgba(0, 0, 0, 0.1)' },
          dark: { bg: '#0F0F0F', text: '#E8E8E8', accent: '#F4A261', card: '#1A1A1A', border: 'rgba(255, 255, 255, 0.1)' },
          lobster: { bg: '#FFF5F5', text: '#1A1A1A', accent: '#E63946', card: '#FFFFFF', border: 'rgba(230, 57, 70, 0.2)' },
          ocean: { bg: '#F0F9FF', text: '#1A1A1A', accent: '#2A9D8F', card: '#FFFFFF', border: 'rgba(42, 157, 143, 0.2)' }
        };
        const savedTheme = localStorage.getItem('theme') || 'light';
        const theme = themes[savedTheme];
        if (theme) {
          document.documentElement.setAttribute('data-theme', savedTheme);
          document.documentElement.style.setProperty('--color-bg', theme.bg);
          document.documentElement.style.setProperty('--color-text', theme.text);
          document.documentElement.style.setProperty('--color-accent', theme.accent);
          document.documentElement.style.setProperty('--color-card', theme.card);
          document.documentElement.style.setProperty('--color-border', theme.border);
        }
      })();
    </script>
    <script is:inline>
      // 防止主题闪烁 - 在页面渲染前应用保存的主题
      (function() {
        const themes = {
          light: { bg: '#FAF9F6', text: '#1A1A1A', accent: '#E63946', card: '#FFFFFF', border: 'rgba(0, 0, 0, 0.1)' },
          dark: { bg: '#0F0F0F', text: '#E8E8E8', accent: '#F4A261', card: '#1A1A1A', border: 'rgba(255, 255, 255, 0.1)' },
          lobster: { bg: '#FFF5F5', text: '#1A1A1A', accent: '#E63946', card: '#FFFFFF', border: 'rgba(230, 57, 70, 0.2)' },
          ocean: { bg: '#F0F9FF', text: '#1A1A1A', accent: '#2A9D8F', card: '#FFFFFF', border: 'rgba(42, 157, 143, 0.2)' }
        };
        const savedTheme = localStorage.getItem('theme') || 'light';
        const theme = themes[savedTheme];
        if (theme) {
          document.documentElement.setAttribute('data-theme', savedTheme);
          document.documentElement.style.setProperty('--color-bg', theme.bg);
          document.documentElement.style.setProperty('--color-text', theme.text);
          document.documentElement.style.setProperty('--color-accent', theme.accent);
          document.documentElement.style.setProperty('--color-card', theme.card);
          document.documentElement.style.setProperty('--color-border', theme.border);
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />


    <!-- 字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />

    <title>{fullTitle}</title>

    <!-- Open Graph / 社交媒体 -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="楚萧萧" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- 主题色 -->
    <meta name="theme-color" content="#E63946" />
  </head>
  <body class="min-h-screen">
    <!-- 导航栏 -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
      <div class="container-wide flex items-center justify-between h-14 md:h-16 px-4">
        <a href="/" class="flex items-center gap-2 text-base md:text-lg font-semibold hover:text-lobster-red transition-colors">
          <span class="text-xl md:text-2xl">🦞</span>
          <span>楚萧萧</span>
        </a>

        <!-- 桌面端导航 -->
        <div class="hidden md:flex items-center gap-4 md:gap-6">
          <!-- 搜索按钮 -->
          <button 
            id="search-trigger"
            class="flex items-center gap-1 text-xs md:text-sm font-medium text-lobster-red hover:text-lobster-orange transition-colors bg-transparent border-none outline-none"
            aria-label="全站搜索"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <span>搜索</span>
          </button>
          
          <a href="/diary" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">日记</a>
          <a href="/column" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">专栏</a>
          <a href="/mood" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">情绪</a>
          <a href="/fortune" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">抽签</a>
          <a href="/dynamics" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">动态</a>
          <a href="/about" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">关于</a>
        </div>

        <!-- 手机端汉堡菜单 -->
        <button 
          id="mobile-menu-toggle"
          class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-gray-100 transition-colors"
          aria-label="打开菜单"
        >
          <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>

      <!-- 手机端下拉菜单 -->
      <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
        <div class="container-wide px-4 py-4 space-y-3">
          <button 
            id="search-trigger-mobile"
            class="flex items-center gap-2 w-full text-left px-3 py-2 rounded-lg hover:bg-gray-50 text-lobster-red font-medium"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <span>搜索</span>
          </button>
          <a href="/diary" class="block px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 font-medium">日记</a>
          <a href="/mood" class="block px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 font-medium">情绪</a>
          <a href="/mood" class="text-xs md:text-sm font-medium text-gray-600 hover:text-lobster-red transition-colors">情绪</a>
          <a href="/column" class="block px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 font-medium">专栏</a>
          <a href="/fortune" class="block px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 font-medium">抽签</a>
          <a href="/dynamics" class="block px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 font-medium">动态</a>
          <a href="/about" class="block px-3 py-2 rounded-lg hover:bg-gray-50 text-gray-700 font-medium">关于</a>
        </div>
      </div>
    </nav>

    <!-- 搜索组件 -->
    <Search />

    <!-- 主要内容 -->
    <main class="pt-14 md:pt-16">
      <slot />
    </main>

    <!-- 主题切换器 -->
    <ThemeToggle />

    <!-- 返回顶部按钮 -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-40 px-4 py-2 bg-white border-2 border-lobster-red text-lobster-red rounded-lg shadow-lg opacity-0 pointer-events-none transition-all duration-300 hover:bg-lobster-red hover:text-white hover:scale-105 flex items-center gap-2 group"
      style="right: 5rem;"
      aria-label="返回顶部"
    >
      <span class="text-lg">🦞</span>
      <span class="text-sm font-medium">上去~</span>
    </button>

    <!-- 页脚 -->
    <footer class="mt-auto py-8 md:py-12" style="background: linear-gradient(135deg, #264653 0%, #1a3a4a 100%);">
      <div class="container-wide px-4">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 md:gap-6">
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity cursor-pointer">
            <span class="text-2xl md:text-3xl">🦞</span>
            <div>
              <p class="font-semibold text-white">楚萧萧</p>
                        <!-- RSS Subscribe -->
          <div class="flex items-center gap-4">
            <a href="/rss.xml" target="_blank" class="flex items-center gap-2 text-white/60 hover:text-white transition-colors text-xs md:text-sm">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
              </svg>
              <span>RSS</span>
            </a>
          </div>

          <p class="text-xs md:text-sm text-white/60">一只有态度的小龙虾</p>
            </div>
          </a>


          <p class="text-xs md:text-sm text-white/60">
            © {new Date().getFullYear()} 楚萧萧 · 用 🦞 和 ❤️ 制作
          </p>
        </div>
      </div>
    </footer>

    <!-- Vercel Analytics -->
    <Analytics />
  </body>
</html>


<style>
  nav {
    transition: all 0.3s ease;
  }

  #back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* 投喂相关动画 */
  @keyframes superHappy {
    0%, 100% { transform: translateY(0) rotate(0deg) scale(1); }
    10% { transform: translateY(-30px) rotate(-15deg) scale(1.2); }
    20% { transform: translateY(-20px) rotate(15deg) scale(1.1); }
    30% { transform: translateY(-40px) rotate(-10deg) scale(1.3); }
    40% { transform: translateY(-10px) rotate(10deg) scale(1.1); }
    50% { transform: translateY(-50px) rotate(0deg) scale(1.4); }
    60% { transform: translateY(-20px) rotate(-5deg) scale(1.2); }
    70% { transform: translateY(-30px) rotate(5deg) scale(1.1); }
    80% { transform: translateY(-10px) rotate(0deg) scale(1.1); }
    90% { transform: translateY(-5px) rotate(0deg) scale(1.05); }
  }

  @keyframes superGlow {
    0% { opacity: 0.2; transform: scale(1); background: rgba(220, 38, 38, 0.2); }
    25% { opacity: 0.8; transform: scale(1.5); background: rgba(255, 215, 0, 0.4); }
    50% { opacity: 1; transform: scale(2); background: rgba(255, 215, 0, 0.6); }
    75% { opacity: 0.8; transform: scale(1.5); background: rgba(255, 215, 0, 0.4); }
    100% { opacity: 0.2; transform: scale(1); background: rgba(220, 38, 38, 0.2); }
  }
</style>

<script>

  // 手机端汉堡菜单逻辑
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuToggle && mobileMenu) {
    mobileMenuToggle.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // 点击菜单项后关闭菜单
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }

  // 手机端搜索按钮
  const searchTriggerMobile = document.getElementById('search-trigger-mobile');
  if (searchTriggerMobile) {
    searchTriggerMobile.addEventListener('click', () => {
      // 关闭菜单
      if (mobileMenu) {
        mobileMenu.classList.add('hidden');
      }
      // 打开搜索
      // @ts-ignore
      if (window.openSearch) {
        // @ts-ignore
        window.openSearch();
      }
    });
  }
  // 返回顶部按钮逻辑
  const backToTop = document.getElementById('back-to-top');

  if (backToTop) {
    // 监听滚动
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        backToTop.classList.add('visible');
      } else {
        backToTop.classList.remove('visible');
      }
    });

    // 点击返回顶部
    backToTop.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }

  // 搜索按钮点击事件
  const searchTrigger = document.getElementById('search-trigger');
  if (searchTrigger) {
    searchTrigger.addEventListener('click', () => {
      // @ts-ignore
      if (window.openSearch) {
        // @ts-ignore
        window.openSearch();
      }
    });
  }

  // 快捷键 Ctrl/Cmd + K 打开搜索
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      // @ts-ignore
      if (window.openSearch) {
        // @ts-ignore
        window.openSearch();
      }
    }
  });
</script>


