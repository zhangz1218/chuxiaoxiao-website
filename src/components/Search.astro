---
// 全站搜索组件 - 基于 Pagefind
---

<div id="search-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[80vh] overflow-hidden border-2 border-lobster-red/20">
    <!-- 搜索头部 -->
    <div class="p-4 bg-gradient-to-r from-lobster-red/10 to-lobster-red/5 border-b border-lobster-red/20 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="text-2xl">🔍</span>
        <h2 class="text-xl font-bold text-lobster-red">全站搜索</h2>
      </div>
      <button id="close-search" class="p-2 hover:bg-lobster-red/10 rounded-lg transition-colors">
        <svg class="w-6 h-6 text-lobster-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- 搜索框 -->
    <div class="p-4">
      <div id="search"></div>
    </div>
    
    <!-- 搜索提示 -->
    <div class="px-4 pb-4 text-sm text-gray-500">
      <p>💡 可以搜索日记、专栏中的内容</p>
      <p class="mt-1">支持关键词、标签搜索</p>
    </div>
  </div>
</div>

<style is:global>
  /* Pagefind 自定义样式 - 小龙虾主题 */
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #E63946;
    --pagefind-ui-text: #1F2937;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #F3F4F6;
    --pagefind-ui-tag: #E63946;
    --pagefind-ui-border-width: 2px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: "Noto Sans SC", sans-serif;
  }
  
  /* 搜索输入框 */
  .pagefind-ui__search-input {
    border: 2px solid #F3F4F6 !important;
    border-radius: 12px !important;
    padding: 12px 16px !important;
    font-size: 16px !important;
    transition: all 0.2s ease !important;
  }
  
  .pagefind-ui__search-input:focus {
    border-color: #E63946 !important;
    box-shadow: 0 0 0 3px rgba(230, 57, 70, 0.1) !important;
    outline: none !important;
  }
  
  /* 搜索结果 */
  .pagefind-ui__result {
    border: 1px solid #F3F4F6 !important;
    border-radius: 12px !important;
    padding: 16px !important;
    margin-bottom: 12px !important;
    transition: all 0.2s ease !important;
  }
  
  .pagefind-ui__result:hover {
    border-color: #E63946 !important;
    box-shadow: 0 4px 12px rgba(230, 57, 70, 0.1) !important;
  }
  
  /* 结果标题 */
  .pagefind-ui__result-title {
    color: #1F2937 !important;
    font-weight: 600 !important;
    font-size: 18px !important;
  }
  
  .pagefind-ui__result-link {
    color: inherit !important;
    text-decoration: none !important;
  }
  
  .pagefind-ui__result-link:hover {
    color: #E63946 !important;
  }
  
  /* 结果摘要 */
  .pagefind-ui__result-excerpt {
    color: #6B7280 !important;
    font-size: 14px !important;
    line-height: 1.6 !important;
    margin-top: 8px !important;
  }
  
  /* 高亮标记 */
  .pagefind-ui__result-mark {
    background: rgba(230, 57, 70, 0.2) !important;
    color: #E63946 !important;
    padding: 2px 4px !important;
    border-radius: 4px !important;
    font-weight: 500 !important;
  }
  
  /* 结果标签 */
  .pagefind-ui__result-tags {
    display: flex !important;
    gap: 8px !important;
    margin-top: 12px !important;
  }
  
  .pagefind-ui__result-tag {
    background: rgba(230, 57, 70, 0.1) !important;
    color: #E63946 !important;
    padding: 4px 12px !important;
    border-radius: 20px !important;
    font-size: 12px !important;
    font-weight: 500 !important;
  }
  
  /* 加载状态 */
  .pagefind-ui__loading {
    color: #E63946 !important;
  }
  
  /* 无结果 */
  .pagefind-ui__message {
    color: #6B7280 !important;
    text-align: center !important;
    padding: 32px !important;
  }
  
  /* 分隔线 */
  .pagefind-ui__drawer {
    border-top: 1px solid #F3F4F6 !important;
    margin-top: 16px !important;
    padding-top: 16px !important;
  }

  /* 清除按钮美化 */
  .pagefind-ui__search-clear {
    background: rgba(230, 57, 70, 0.1) !important;
    color: #E63946 !important;
    border: 1px solid rgba(230, 57, 70, 0.3) !important;
    padding: 6px 16px !important;
    border-radius: 20px !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    cursor: pointer !important;
    transition: all 0.2s ease !important;
  }
  
  .pagefind-ui__search-clear:hover {
    background: #E63946 !important;
    color: white !important;
    border-color: #E63946 !important;
  }
</style>

<script>
  // 初始化 Pagefind
  async function initPagefind() {
    const searchModal = document.getElementById('search-modal');
    const searchContainer = document.getElementById('search');
    
    if (!searchContainer) return;
    
    try {
      // @ts-ignore - Pagefind UI
      const { PagefindUI } = await import('@pagefind/default-ui');
      
      // 清空容器
      searchContainer.innerHTML = '';
      
      // 创建搜索UI
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: '搜索日记、专栏...',
          zero_results: '没有找到 [SEARCH_TERM] 相关内容',
          many_results: '找到 [COUNT] 个结果',
          one_result: '找到 1 个结果',
          searching: '搜索中...',
          clear_search: '清除',
          load_more: '更多结果',
          total_many_results: '[COUNT] 个结果',
          total_one_result: '1 个结果',
          total_zero_results: '没有结果'
        }
      });
    } catch (error) {
      console.error('Pagefind 初始化失败:', error);
      searchContainer.innerHTML = `
        <div class="text-center py-8 text-gray-500">
          <p>搜索功能正在加载中...</p>
          <p class="text-sm mt-2">如果持续出现，请刷新页面重试</p>
        </div>
      `;
    }
  }
  
  // 打开搜索弹窗
  function openSearch() {
    const modal = document.getElementById('search-modal');
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      initPagefind();
      
      // 聚焦搜索框
      setTimeout(() => {
        const input = modal.querySelector('input');
        if (input) input.focus();
      }, 100);
    }
  }
  
  // 关闭搜索弹窗
  function closeSearch() {
    const modal = document.getElementById('search-modal');
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
  }
  
  // 绑定事件
  document.addEventListener('DOMContentLoaded', () => {
    // 关闭按钮
    const closeBtn = document.getElementById('close-search');
    if (closeBtn) {
      closeBtn.addEventListener('click', closeSearch);
    }
    
    // 点击背景关闭
    const modal = document.getElementById('search-modal');
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeSearch();
        }
      });
    }
    
    // ESC 键关闭
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeSearch();
      }
    });
  });
  
  // 暴露全局方法
  (window as any).openSearch = openSearch;
  (window as any).closeSearch = closeSearch;
</script>
