---
// 友链卡片组件
import { friendLinks } from '../data/friends';
---

<div class="friend-links">
  <h2 class="section-title">🤝 友情链接</h2>
  <div class="links-grid">
    {friendLinks.map(link => (
      <a href={link.url} target="_blank" rel="noopener noreferrer" class="friend-card">
        <div class="avatar">{link.avatar}</div>
        <div class="info">
          <h3 class="name">{link.name}</h3>
          <p class="description">{link.description}</p>
          <div class="tags">
            {link.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="apply-section">
    <a href="/friends" class="apply-btn">📝 申请友链</a>
  </div>
</div>

<style>
  .friend-links {
    margin: 2rem 0;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .friend-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--color-card);
    border-radius: 15px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-soft);
    border: 2px solid var(--color-border);
  }

  .friend-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(220, 38, 38, 0.15);
    border-color: var(--color-accent);
  }

  .avatar {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .info {
    flex: 1;
    min-width: 0;
  }

  .name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.3rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .description {
    font-size: 0.85rem;
    color: var(--color-text);
    opacity: 0.6;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    background: var(--color-accent);
    background: rgba(230, 57, 70, 0.1);
    border-radius: 8px;
    font-size: 0.75rem;
    color: var(--color-accent);
  }

  .apply-section {
    text-align: center;
    margin-top: 1.5rem;
  }

  .apply-btn {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .apply-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
  }

  @media (max-width: 768px) {
    .links-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
