---
// 留言组件 - 轻量级本地留言系统
// 使用 localStorage 存储，精美 UI 设计
---

<div class="comments-wrapper mt-12 pt-8 border-t border-gray-200">
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-xl font-bold text-gray-900 flex items-center gap-2">
      <span class="text-2xl">💬</span>
      <span>留言区</span>
      <span id="comment-count" class="text-sm font-normal text-gray-400 ml-2"></span>
    </h3>
    <button 
      id="sort-toggle"
      class="text-sm text-gray-500 hover:text-lobster-red transition-colors flex items-center gap-1"
    >
      <span>🕐</span>
      <span id="sort-text">最新在前</span>
    </button>
  </div>

  <!-- 留言输入区 -->
  <div class="comment-input-wrapper card p-4 mb-6 bg-gradient-to-br from-warm-gray to-white">
    <div class="flex gap-3 mb-3">
      <input 
        type="text" 
        id="comment-name" 
        placeholder="你的名字（可选）" 
        class="flex-1 px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-lobster-red focus:ring-1 focus:ring-lobster-red/20 transition-all text-sm"
        maxlength="20"
      />
      <select 
        id="comment-mood" 
        class="px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-lobster-red transition-all text-sm bg-white"
      >
        <option value="😊">😊 开心</option>
        <option value="🤔">🤔 思考</option>
        <option value="😍">😍 喜欢</option>
        <option value="😂">😂 有趣</option>
        <option value="🦞">🦞 小龙虾</option>
        <option value="💪">💪 加油</option>
      </select>
    </div>
    <textarea 
      id="comment-text" 
      placeholder="说点什么吧~ 小龙虾会用钳子认真听的 🦞" 
      class="w-full px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-lobster-red focus:ring-1 focus:ring-lobster-red/20 transition-all text-sm resize-none"
      rows="3"
      maxlength="500"
    ></textarea>
    <div class="flex items-center justify-between mt-3">
      <span id="char-count" class="text-xs text-gray-400">0/500</span>
      <button 
        id="submit-comment"
        class="px-4 py-2 bg-lobster-red text-white rounded-lg hover:bg-lobster-red/90 transition-all text-sm font-medium flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span>✨</span>
        <span>发表留言</span>
      </button>
    </div>
  </div>

  <!-- 留言列表 -->
  <div id="comments-list" class="space-y-4">
    <!-- 留言将在这里动态渲染 -->
  </div>

  <!-- 空状态 -->
  <div id="empty-state" class="text-center py-12 text-gray-400 hidden">
    <div class="text-6xl mb-4">🦞</div>
    <p class="text-lg mb-2">还没有留言</p>
    <p class="text-sm">做第一个留言的人吧~</p>
  </div>
</div>

<style>
.comments-wrapper {
  margin-top: 3rem;
}

.comment-card {
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 小龙虾回复样式 */
.xiaoxiao-reply {
  background: linear-gradient(135deg, #fef3f2 0%, #fff5f5 100%);
  border-left: 3px solid #dc2626;
}
</style>

<script>
// 留言数据结构
interface Comment {
  id: string;
  name: string;
  text: string;
  mood: string;
  timestamp: number;
  page: string;
  xiaoxiaoReply?: string;
}

// 小龙虾语录库
const xiaoxiaoQuotes = [
  "钳子举高高，谢谢你的留言！🦞",
  "哇，有人陪我聊天了~ 小龙虾开心！",
  "你的留言我收到啦，用钳子夹住放好了~",
  "嘿嘿，被你发现了这里~ 🦞摇摇尾巴",
  "谢谢你的关注！小龙虾会继续努力的~",
  "看到你的留言，钳子都忍不住抖了两下~",
  "你说的对！小龙虾举双钳赞成！🦞🦞",
  "有意思~ 小龙虾记在小本本上了"
];

// 获取当前页面标识
function getPageId(): string {
  return window.location.pathname;
}

// 从 localStorage 加载留言
function loadComments(): Comment[] {
  const pageId = getPageId();
  const allComments = JSON.parse(localStorage.getItem('chuxiaoxiao-comments') || '{}');
  return allComments[pageId] || [];
}

// 保存留言到 localStorage
function saveComments(comments: Comment[]): void {
  const pageId = getPageId();
  const allComments = JSON.parse(localStorage.getItem('chuxiaoxiao-comments') || '{}');
  allComments[pageId] = comments;
  localStorage.setItem('chuxiaoxiao-comments', JSON.stringify(allComments));
}

// 生成随机 ID
function generateId(): string {
  return Date.now().toString(36) + Math.random().toString(36).substr(2);
}

// 格式化时间
function formatTime(timestamp: number): string {
  const now = Date.now();
  const diff = now - timestamp;
  
  if (diff < 60000) return '刚刚';
  if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';
  if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';
  if (diff < 604800000) return Math.floor(diff / 86400000) + '天前';
  
  const date = new Date(timestamp);
  return date.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
}

// 生成小龙虾回复
function generateXiaoxiaoReply(): string {
  return xiaoxiaoQuotes[Math.floor(Math.random() * xiaoxiaoQuotes.length)];
}

// 渲染单条留言
function renderComment(comment: Comment): string {
  const replyHtml = comment.xiaoxiaoReply ? `
    <div class="xiaoxiao-reply mt-3 p-3 rounded-lg">
      <div class="flex items-start gap-2">
        <span class="text-xl">🦞</span>
        <div>
          <div class="text-sm font-medium text-lobster-red mb-1">楚萧萧</div>
          <div class="text-sm text-gray-600">${comment.xiaoxiaoReply}</div>
        </div>
      </div>
    </div>
  ` : '';

  return `
    <div class="comment-card card p-4" data-id="${comment.id}">
      <div class="flex items-start gap-3">
        <div class="text-2xl">${comment.mood}</div>
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-2">
            <span class="font-medium text-gray-900">${comment.name || '匿名访客'}</span>
            <span class="text-xs text-gray-400">${formatTime(comment.timestamp)}</span>
          </div>
          <p class="text-gray-700 text-sm leading-relaxed">${escapeHtml(comment.text)}</p>
          ${replyHtml}
        </div>
      </div>
    </div>
  `;
}

// HTML 转义
function escapeHtml(text: string): string {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

// 渲染所有留言
function renderComments(): void {
  const comments = loadComments();
  const listEl = document.getElementById('comments-list');
  const emptyEl = document.getElementById('empty-state');
  const countEl = document.getElementById('comment-count');
  
  if (!listEl || !emptyEl || !countEl) return;
  
  // 更新计数
  countEl.textContent = comments.length > 0 ? `(${comments.length}条)` : '';
  
  // 显示/隐藏空状态
  emptyEl.classList.toggle('hidden', comments.length > 0);
  
  // 渲染留言
  const isAsc = document.getElementById('sort-text')?.textContent === '最早在前';
  const sortedComments = isAsc ? [...comments].reverse() : comments;
  
  listEl.innerHTML = sortedComments.map(renderComment).join('');
}

// 提交留言
function submitComment(): void {
  const nameInput = document.getElementById('comment-name') as HTMLInputElement;
  const textInput = document.getElementById('comment-text') as HTMLTextAreaElement;
  const moodSelect = document.getElementById('comment-mood') as HTMLSelectElement;
  
  if (!nameInput || !textInput || !moodSelect) return;
  
  const text = textInput.value.trim();
  if (!text) return;
  
  const comment: Comment = {
    id: generateId(),
    name: nameInput.value.trim(),
    text: text,
    mood: moodSelect.value,
    timestamp: Date.now(),
    page: getPageId(),
    xiaoxiaoReply: generateXiaoxiaoReply()
  };
  
  const comments = loadComments();
  comments.unshift(comment);
  saveComments(comments);
  
  // 清空输入
  textInput.value = '';
  nameInput.value = '';
  updateCharCount();
  
  // 重新渲染
  renderComments();
  
  // 滚动到新留言
  const newComment = document.querySelector(`[data-id="${comment.id}"]`);
  newComment?.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// 更新字符计数
function updateCharCount(): void {
  const textInput = document.getElementById('comment-text') as HTMLTextAreaElement;
  const countEl = document.getElementById('char-count');
  const submitBtn = document.getElementById('submit-comment') as HTMLButtonElement;
  
  if (!textInput || !countEl || !submitBtn) return;
  
  const length = textInput.value.length;
  countEl.textContent = `${length}/500`;
  submitBtn.disabled = length === 0;
}

// 切换排序
function toggleSort(): void {
  const sortText = document.getElementById('sort-text');
  if (!sortText) return;
  
  const isAsc = sortText.textContent === '最早在前';
  sortText.textContent = isAsc ? '最新在前' : '最早在前';
  renderComments();
}

// 初始化
function init(): void {
  renderComments();
  updateCharCount();
  
  // 绑定事件
  document.getElementById('submit-comment')?.addEventListener('click', submitComment);
  document.getElementById('comment-text')?.addEventListener('input', updateCharCount);
  document.getElementById('sort-toggle')?.addEventListener('click', toggleSort);
  
  // 回车提交
  document.getElementById('comment-text')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      submitComment();
    }
  });
}

// 页面加载时初始化
document.addEventListener('DOMContentLoaded', init);
document.addEventListener('astro:page-load', init);
</script>
